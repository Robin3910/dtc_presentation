# AI 素材审核助手 · Step 2 环境变量配置示例
# ================================
# 复制此文件为 .env 并填写实际值
# Linux/Mac: cp .env.example .env
# Windows: copy .env.example .env

# ============================================
# 服务器配置
# ============================================
APP_HOST=0.0.0.0
APP_PORT=8080
APP_DEBUG=false

# ============================================
# AI 审核配置（必须配置）
# ============================================
# DMXAPI 中转站 API Key
DMXAPI_API_KEY=sk-your-api-key-here
DMXAPI_BASE_URL=https://www.dmxapi.cn
CLAUDE_MODEL=kimi-k2.6

# ============================================
# 邮件发送配置（必须配置）
# ============================================
SENDER_EMAIL=your-email@foxmail.com
SENDER_NAME=AI 素材审核助手
SMTP_HOST=smtp.exmail.qq.com
SMTP_PORT=465
SMTP_USER=your-email@foxmail.com
SMTP_PASS=your-smtp-auth-code

# 运营团队通知邮箱
OPERATION_TEAM_EMAIL=operation@example.com

# ============================================
# 管理后台认证（必须修改）
# ============================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password-here

# ============================================
# 云存储配置（可选）
# ============================================
# 是否使用云存储（true/false）
USE_CLOUD_STORAGE=false

# 云存储提供商（tencent/aliyun）
COS_PROVIDER=tencent

# 腾讯云 COS
TENCENT_SECRET_ID=your-tencent-secret-id
TENCENT_SECRET_KEY=your-tencent-secret-key
TENCENT_COS_REGION=ap-guangzhou
TENCENT_COS_BUCKET=your-bucket-name

# 阿里云 OSS
ALIYUN_ACCESS_KEY_ID=your-aliyun-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_BUCKET=your-bucket-name

# ============================================
# 审核调度配置
# ============================================
# 是否启用自动审核
ENABLE_AUTO_REVIEW=true
# 扫描间隔（分钟）
REVIEW_INTERVAL=5
